{
  "name": "opium-league",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "NODE_OPTIONS='--openssl-legacy-provider --no-deprecation' ng serve",
    "build": "NODE_OPTIONS='--openssl-legacy-provider --no-deprecation' ng build --prod --outputHashing=all",
    "test": "NODE_OPTIONS='--openssl-legacy-provider --no-deprecation' ng test",
    "lint": "NODE_OPTIONS='--openssl-legacy-provider --no-deprecation' ng lint",
    "e2e": "NODE_OPTIONS='--openssl-legacy-provider --no-deprecation' ng e2e",
    "check": "npm run lint && npm test --watch=false --browsers ChromeHeadless && npm run build"
  },
  "private": true,
